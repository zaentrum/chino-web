# chino web client — build-time configuration.
# Copy to .env.local and fill in for your deployment. All values are
# read at build time by Vite (VITE_* prefix) and baked into the bundle.

# Your server's OIDC issuer (the authority / realm URL that serves the
# OpenID Connect discovery document at /.well-known/openid-configuration).
# Required. Leave empty here; set it for your own server.
VITE_OIDC_AUTHORITY=

# OIDC client id this web app registers as. The default identifier is
# "chino" — match it to the client you configure on your OIDC provider.
VITE_OIDC_CLIENT_ID=chino

# Optional. When unset, the redirect and post-logout URIs default to the
# page origin the app is served from (window.location.origin) — for a
# same-origin deployment you normally do NOT need to set these.
#VITE_OIDC_REDIRECT_URI=
#VITE_OIDC_POST_LOGOUT_REDIRECT_URI=
